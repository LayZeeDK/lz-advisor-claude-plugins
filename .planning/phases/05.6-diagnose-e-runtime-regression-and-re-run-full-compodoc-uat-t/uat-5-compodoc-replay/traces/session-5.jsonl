mponents:build-storybook\",\n    \"compodoc\": true\n  },\n  \"configurations\": {\n    \"ci\": { \"quiet\": true }\n  }\n},\n\"build-storybook\": {\n  \"executor\": \"@storybook/angular:build-storybook\",\n  \"outputs\": [\"{options.outputDir}\"],\n  \"options\": {\n    \"outputDir\": \"dist/storybook/ngx-smart-components\",\n    \"configDir\": \"packages/ngx-smart-components/.storybook\",\n    \"browserTarget\": \"ngx-smart-components:build-storybook\",\n    \"compodoc\": true\n  },\n  \"configurations\": {\n    \"ci\": { \"quiet\": true }\n  }\n}\n```\n\n`packages/ngx-smart-components/.storybook/preview.ts`:\n```typescript\nimport { global } from '@storybook/global';\n\nimport('../../../documentation.json')\n  .then(({ default: docJson }) => {\n    (global as Record<string, unknown>)['__STORYBOOK_COMPODOC_JSON__'] = docJson;\n  })\n  .catch(() => undefined);\n```\n\n`packages/ngx-smart-components/.storybook/documentation.d.ts`:\n```typescript\ndeclare module '*/documentation.json' {\n  const value: unknown;\n  export default value;\n}\n```\n\n`packages/ngx-smart-components/src/lib/ngx-smart-components/ngx-smart-components.stories.ts` (meta only):\n```typescript\nconst meta: Meta<NgxSmartComponents> = {\n  component: NgxSmartComponents,\n  title: 'NgxSmartComponents',\n};\n```\n\n## Plan Steps to Implement\n\n1. Add `compodoc` target to `project.json` using `nx:run-commands`:\n```json\n\"compodoc\": {\n  \"executor\": \"nx:run-commands\",\n  \"outputs\": [\"{workspaceRoot}/documentation.json\"],\n  \"options\": {\n    \"command\": \"npx compodoc -p packages/ngx-smart-components/.storybook/tsconfig.doc.json -e json -d .\"\n  }\n}\n```\n\n2. Set `\"compodoc\": false` on `storybook` and `build-storybook` targets; add `\"dependsOn\": [\"compodoc\"]` at target level.\n\n3. Add `tags: ['autodocs']` to story meta.\n\n4. Replace type cast in `preview.ts` with `declare global` Window augmentation. Plan suggests either adding to `preview.ts` or a separate `documentation.d.t